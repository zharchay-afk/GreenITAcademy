rules_version = '2';

// Règles de sécurité Firestore — Green IT Académie
// À copier dans Firebase Console → Firestore → Règles
service cloud.firestore {
  match /databases/{database}/documents {

    // Chaque utilisateur peut lire et écrire uniquement ses propres données
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Aucun autre accès n'est autorisé
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Vérifie si l'utilisateur connecté a le rôle admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Données utilisateur : chacun accède uniquement à son propre document
    // Les admins peuvent lire tous les documents (pour l'onglet Utilisateurs)
    match /users/{userId} {
      allow read:  if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Contenu des modules : lecture libre, écriture réservée aux admins
    match /content_modules/{moduleId} {
      allow read:  if true;
      allow write: if isAdmin();

      // Historique des versions (sous-collection)
      match /versions/{versionId} {
        allow read:  if isAdmin();
        allow write: if isAdmin();
      }
    }

    // Questions : lecture libre (quiz), écriture réservée aux admins
    match /content_questions/{questionId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Configuration du site (landing page, branding) : lecture libre, écriture admin
    match /config/{configId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Tout le reste est refusé
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

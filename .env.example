# ============================================================
# Green IT Académie — Variables d'environnement Firebase
# ============================================================
#
# INSTRUCTIONS :
# 1. Copie ce fichier en ".env.local" (à la racine du projet)
# 2. Remplis les valeurs avec ta config Firebase
#    (console.firebase.google.com → Paramètres → Tes applications → Web)
# 3. Lance le projet : npm run dev
#
# ⚠️ Ne jamais committer .env.local (il est dans .gitignore)
# ============================================================

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=ton-projet.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ton-projet
VITE_FIREBASE_STORAGE_BUCKET=ton-projet.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
